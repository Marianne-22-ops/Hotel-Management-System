<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.DashboardController"
            style="-fx-background-color:#f5f7fa;">

    <children>

        <BorderPane prefHeight="500.0" prefWidth="800.0">

            <!-- HEADER -->
            <top>
                <AnchorPane prefHeight="70.0" style="-fx-background-color:#1e293b;">
                    <children>
                        <Label layoutX="200.0" layoutY="18.0"
                               text="Hotel Management Dashboard"
                               textFill="WHITE">
                            <font>
                                <Font size="26.0"/>
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
            </top>

            <!-- SIDEBAR -->
            <left>
                <VBox prefWidth="200.0" spacing="12.0"
                      style="-fx-background-color:#0f172a;">
                    <padding>
                        <Insets left="15.0" top="25.0"/>
                    </padding>

                    <children>
                        <Button text="Dashboard" onAction="#handleDashboard"/>
                        <Button text="Manage Rooms" onAction="#handleRooms"/>
                        <Button text="Manage Guests" onAction="#handleGuests"/>
                        <Button text="Reservations" onAction="#handleReservations"/>
                        <Button text="Payments" onAction="#handlePayments"/>
                        <Button text="Reports" onAction="#handleReports"/>
                        <Button text="Logout" onAction="#handleLogout"
                                style="-fx-background-color:#ef4444; -fx-text-fill:white;"/>
                    </children>
                </VBox>
            </left>

            <!-- CENTER -->
            <center>
                <AnchorPane fx:id="workspacePane"
                            style="-fx-background-color:#f8fafc;">

                    <children>

                        <!-- SUMMARY CARDS -->
                        <HBox spacing="15" layoutX="30" layoutY="20">

                            <VBox prefWidth="170"
                                  style="-fx-background-color:#3b82f6; -fx-padding:12; -fx-background-radius:10;">
                                <Label text="Total Rooms" style="-fx-text-fill:white;"/>
                                <Label fx:id="lblRooms"
                                       text="0"
                                       style="-fx-text-fill:white; -fx-font-size:18px;"/>
                            </VBox>

                            <VBox prefWidth="170"
                                  style="-fx-background-color:#f97316; -fx-padding:12; -fx-background-radius:10;">
                                <Label text="Guests" style="-fx-text-fill:white;"/>
                                <Label fx:id="lblGuests"
                                       text="0"
                                       style="-fx-text-fill:white; -fx-font-size:18px;"/>
                            </VBox>

                            <VBox prefWidth="170"
                                  style="-fx-background-color:#10b981; -fx-padding:12; -fx-background-radius:10;">
                                <Label text="Revenue" style="-fx-text-fill:white;"/>
                                <Label fx:id="lblRevenue"
                                       text="0"
                                       style="-fx-text-fill:white; -fx-font-size:18px;"/>
                            </VBox>

                        </HBox>

                        <!-- PIE CHART -->
                        <PieChart fx:id="roomChart"
                                  layoutX="150"
                                  layoutY="120"
                                  prefWidth="450"
                                  prefHeight="300"/>

                    </children>

                </AnchorPane>
            </center>

        </BorderPane>

    </children>
</AnchorPane>