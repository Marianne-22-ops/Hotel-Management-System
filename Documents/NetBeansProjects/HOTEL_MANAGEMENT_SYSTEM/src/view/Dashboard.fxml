<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #f5f7fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

   <children>

      <BorderPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #94a3b8">

         <!-- 🔝 TOP HEADER -->
         <top>
            <AnchorPane prefHeight="70.0" style="-fx-background-color: #1e293b;">
               <children>
                  <Label layoutX="304.0" layoutY="19.0" text="Hotel Management Dashboard" textFill="WHITE">
                     <font>
                        <Font name="Berlin Sans FB" size="28.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
         </top>

         <!-- 📌 LEFT SIDEBAR -->
         <left>
            <VBox prefWidth="200.0" spacing="12.0" style="-fx-background-color: #0f172a;" BorderPane.alignment="CENTER">

               <padding>
                  <Insets left="15.0" top="25.0" />
               </padding>

               <children>
                  <Button style="-fx-background-color:#3b82f6; -fx-text-fill:white; -fx-background-radius:8;" text="Dashboard" />

                  <Button onAction="#handleRooms" style="-fx-text-fill:black; -fx-background-radius:8;" text="Manage Rooms" />

                  <Button onAction="#handleGuests" style="-fx-text-fill:black; -fx-background-radius:8;" text="Manage Guests" />

                  <Button onAction="#handleReservations" style="-fx-text-fill:black; -fx-background-radius:8;" text="Reservations" />

                  <Button onAction="#handlePayments" style="-fx-text-fill:black; -fx-background-radius:8;" text="Payments" />

                  <Button onAction="#handleReports" style="-fx-text-fill:black; -fx-background-radius:8;" text="Reports" />

                  <Button style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-background-radius:8;" text="Logout" />
               </children>
            </VBox>
         </left>

         <!-- 🧩 CENTER CONTENT -->
         <center>
            <AnchorPane fx:id="workspacePane" style="-fx-background-color: #f8fafc;" BorderPane.alignment="CENTER">

               <children>

                  <!-- Welcome Text -->
                  <Label layoutX="169.0" layoutY="36.0" style="-fx-font-size: 20px; -fx-text-fill:#1e293b;" text="Welcome to Hotel Dashboard">
                     <font>
                        <Font name="Century Gothic Bold" size="12.0" />
                     </font></Label>

                  <!-- Simple Cards -->
                  <VBox layoutX="244.0" layoutY="110.0" spacing="15.0">
   
                     <Label style="-fx-background-color:white; -fx-padding:10; -fx-background-radius:10;" text="Total Rooms: 120" />

                     <Label style="-fx-background-color:white; -fx-padding:10; -fx-background-radius:10;" text="Guests: 85" />

                     <Label style="-fx-background-color:white; -fx-padding:10; -fx-background-radius:10;" text="Revenue: $5000" />

                  </VBox>

               </children>
            </AnchorPane>
         </center>

      </BorderPane>

   </children>
</AnchorPane>
