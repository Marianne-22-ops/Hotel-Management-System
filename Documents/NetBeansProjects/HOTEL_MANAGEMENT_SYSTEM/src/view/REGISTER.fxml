<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #e2e8f0;">

    <children>

        <!-- CENTER CONTAINER -->
        <StackPane AnchorPane.topAnchor="0"
                   AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0"
                   AnchorPane.rightAnchor="0">

            <!-- FORM BOX -->
            <VBox spacing="15"
                  alignment="CENTER"
                  maxWidth="340"
                  style="
                    -fx-border-color:#cbd5e1;
                    -fx-border-width:1.5;
                    -fx-border-radius:12;
                    -fx-background-radius:12;
                    -fx-padding:25;
                    -fx-background-color: rgba(255,255,255,0.7);
                  ">

                <!-- TITLE -->
                <Label text="Register"
                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1e293b;"/>

                <!-- INPUTS -->
                <TextField promptText="Full Name" prefWidth="260"/>
                <TextField promptText="Username" prefWidth="260"/>
                <PasswordField promptText="Password" prefWidth="260"/>
                <PasswordField promptText="Confirm Password" prefWidth="260"/>

                <!-- BUTTON -->
                <Button text="Register"
                        prefWidth="260"
                        style="
                          -fx-background-color:#22c55e;
                          -fx-text-fill:white;
                          -fx-background-radius:8;
                        "/>

                <!-- LINK -->
                <Label text="Already have an account? Login"
                       style="-fx-text-fill:#3b82f6; -fx-font-size:12px;"/>

            </VBox>

        </StackPane>

    </children>
</AnchorPane>