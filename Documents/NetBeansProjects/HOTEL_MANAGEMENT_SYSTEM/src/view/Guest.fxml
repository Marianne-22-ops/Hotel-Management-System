<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.GuestController"
            style="-fx-background-color:#1e293b;">

    <children>

        <VBox spacing="20"
              AnchorPane.topAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20"
              AnchorPane.bottomAnchor="20">

            <!-- TITLE -->
            <Label text="Guest Management"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>

            <!-- FORM BOX -->
            <VBox spacing="12"
                  style="-fx-background-color:rgba(255,255,255,0.8); -fx-padding:15; -fx-background-radius:12;">

                <!-- ROW 1 -->
                <HBox spacing="10">
                    <TextField fx:id="nameField" promptText="Guest Name" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="contactField" promptText="Contact Number"/>
                    <TextField fx:id="emailField" promptText="Email"/>
                </HBox>

                <!-- ROW 2 -->
                <HBox spacing="10">
                    <TextField fx:id="addressField" promptText="Address" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="idTypeCombo" promptText="ID Type"/>
                    <TextField fx:id="idNumberField" promptText="ID Number"/>
                </HBox>

                <!-- BUTTONS -->
                <HBox spacing="10">

                    <Button text="Add Guest"
                            onAction="#addGuest"
                            />

                    <Button text="Edit Guest"
                            onAction="#editGuest"
                            />

                    <Button text="Delete Guest"
                            onAction="#deleteGuest"
                            />

                </HBox>

                <!-- SEARCH -->
                <HBox spacing="10">

                    <TextField fx:id="searchField"
                               promptText="Search Guest Name"
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Search"
                            onAction="#searchGuest"
                            />

                </HBox>

            </VBox>

            <!-- TABLE -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color:rgba(255,255,255,0.8); -fx-padding:15; -fx-background-radius:12;">

                <TableView fx:id="guestTable" VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colName" text="Name" prefWidth="140"/>
                        <TableColumn fx:id="colContact" text="Contact" prefWidth="120"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                        <TableColumn fx:id="colAddress" text="Address" prefWidth="150"/>
                        <TableColumn fx:id="colIdType" text="ID Type" prefWidth="120"/>
                        <TableColumn fx:id="colIdNumber" text="ID No." prefWidth="120"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </children>
</AnchorPane>