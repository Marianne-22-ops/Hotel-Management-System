<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.RoomController"
            style="-fx-background-color:#1e293b;">

    <children>

        <VBox spacing="20"
              AnchorPane.topAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20"
              AnchorPane.bottomAnchor="20">

            <Label text="Room Management"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>


            <!-- FORM BOX -->
            <VBox spacing="12"
                  style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:12;">

                <!-- INPUT FIELDS -->
                <HBox spacing="10">

                    <TextField fx:id="roomNoField"
                               promptText="Room No"
                               HBox.hgrow="ALWAYS"/>

                    <ComboBox fx:id="typeCombo"
                              promptText="Type"
                              prefWidth="150"/>

                    <TextField fx:id="priceField"
                               promptText="Price"
                               HBox.hgrow="ALWAYS"/>

                    <ComboBox fx:id="statusCombo"
                              promptText="Status"
                              prefWidth="150"/>

                </HBox>


                <!-- BUTTONS -->
                <HBox spacing="10">

                    <Button text="Add Room"
                            onAction="#addRoom"/>

                    <Button text="Update Room"
                            onAction="#updateRoom"/>

                    <Button text="Delete Room"
                            onAction="#deleteRoom"/>

                    <Button text="Change Status"
                            onAction="#changeStatus"/>

                </HBox>


                <!-- SEARCH -->
                <HBox spacing="10">

                    <TextField fx:id="searchField"
                               promptText="Search Room Number"
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Search Room"
                            onAction="#searchRoom"/>

                </HBox>

            </VBox>


            <!-- TABLE -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:12;">

                <TableView fx:id="roomTable"
                           VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colRoomNo"
                                     text="Room No"/>

                        <TableColumn fx:id="colType"
                                     text="Type"/>

                        <TableColumn fx:id="colPrice"
                                     text="Price"/>

                        <TableColumn fx:id="colStatus"
                                     text="Status"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </children>

</AnchorPane>