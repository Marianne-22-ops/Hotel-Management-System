<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true"
            fitToHeight="false"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ReservationController"
            style="-fx-background-color:#1e293b;
                   -fx-background:#1e293b;"
            prefWidth="650"
            prefHeight="462"
            minWidth="650"
            minHeight="462">

    <content>
        <VBox spacing="12"
              style="-fx-background-color:#1e293b;
                     -fx-padding:16;">

            <!-- PAGE TITLE -->
            <Label text="Reservations"
                   style="-fx-font-size:18px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#f1f5f9;"/>

            <!-- FORM CARD -->
            <VBox spacing="10"
                  style="-fx-background-color:white;
                         -fx-padding:14;
                         -fx-background-radius:10;">

                <Label text="RESERVATION DETAILS"
                       style="-fx-font-size:10px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#94a3b8;"/>

                <!-- INPUT ROW -->
                <HBox spacing="10">

                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Guest"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="guestCombo"
                                  promptText="Select Guest"
                                  prefHeight="32"
                                  maxWidth="1.7976931348623157E308"
                                  style="-fx-background-color:#f8fafc;
                                         -fx-border-color:#e2e8f0;
                                         -fx-border-radius:6;
                                         -fx-background-radius:6;
                                         -fx-font-size:13px;"
                                  HBox.hgrow="ALWAYS"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="140">
                        <Label text="Room"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="roomCombo"
                                  promptText="Select Room"
                                  prefHeight="32"
                                  prefWidth="140"
                                  style="-fx-background-color:#f8fafc;
                                         -fx-border-color:#e2e8f0;
                                         -fx-border-radius:6;
                                         -fx-background-radius:6;
                                         -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="155">
                        <Label text="Check-In Date"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <DatePicker fx:id="checkInDate"
                                    prefHeight="32"
                                    prefWidth="155"
                                    style="-fx-background-color:#f8fafc;
                                           -fx-border-color:#e2e8f0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="155">
                        <Label text="Check-Out Date"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <DatePicker fx:id="checkOutDate"
                                    prefHeight="32"
                                    prefWidth="155"
                                    style="-fx-background-color:#f8fafc;
                                           -fx-border-color:#e2e8f0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="130">
                        <Label text="Status"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="statusCombo"
                                  promptText="Status"
                                  prefHeight="32"
                                  prefWidth="130"
                                  style="-fx-background-color:#f8fafc;
                                         -fx-border-color:#e2e8f0;
                                         -fx-border-radius:6;
                                         -fx-background-radius:6;
                                         -fx-font-size:13px;"/>
                    </VBox>

                </HBox>

                <Separator/>

                <!-- ACTIONS -->
                <Label text="ACTIONS"
                       style="-fx-font-size:10px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="Create" onAction="#createReservation" prefHeight="32"
                            style="-fx-background-color:#2563eb; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>
                    <Button text="Update" onAction="#updateReservation" prefHeight="32"
                            style="-fx-background-color:#0f766e; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>
                    <Button text="Delete" onAction="#cancelReservation" prefHeight="32"
                            style="-fx-background-color:#dc2626; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="searchField"
                               promptText="Search Guest..."
                               prefHeight="32"
                               prefWidth="200"
                               style="-fx-background-color:#f8fafc;
                                      -fx-border-color:#e2e8f0;
                                      -fx-border-radius:6;
                                      -fx-background-radius:6;
                                      -fx-padding:4 10;
                                      -fx-font-size:13px;"/>
                    <Button text="Search" onAction="#searchReservation" prefHeight="32"
                            style="-fx-background-color:#0f172a; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>
                </HBox>

            </VBox>

            <!-- RESERVATIONS TABLE CARD -->
            <VBox spacing="8"
                  style="-fx-background-color:white;
                         -fx-padding:14;
                         -fx-background-radius:10;">

                <Label text="RESERVATION LIST"
                       style="-fx-font-size:10px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#94a3b8;"/>

                <TableView fx:id="reservationTable"
                           prefHeight="250"
                           maxWidth="1.7976931348623157E308"
                           style="-fx-background-color:transparent;
                                  -fx-border-color:#e2e8f0;
                                  -fx-border-radius:7;
                                  -fx-background-radius:7;
                                  -fx-table-cell-border-color:#f1f5f9;
                                  -fx-font-size:13px;">
                    <columns>
                        <TableColumn fx:id="colGuest"    text="Guest"      prefWidth="200"/>
                        <TableColumn fx:id="colRoom"     text="Room"       prefWidth="150"/>
                        <TableColumn fx:id="colCheckIn"  text="Check-In"   prefWidth="180"/>
                        <TableColumn fx:id="colCheckOut" text="Check-Out"  prefWidth="180"/>
                        <TableColumn fx:id="colStatus"   text="Status"     prefWidth="150"/>
                    </columns>
                </TableView>

            </VBox>

            <!-- HISTORY TABLE CARD -->
            <VBox spacing="8"
                  style="-fx-background-color:white;
                         -fx-padding:14;
                         -fx-background-radius:10;">

                <Label text="RESERVATION HISTORY"
                       style="-fx-font-size:10px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#94a3b8;"/>

                <TableView fx:id="historyTable"
                           prefHeight="220"
                           maxWidth="1.7976931348623157E308"
                           style="-fx-background-color:transparent;
                                  -fx-border-color:#e2e8f0;
                                  -fx-border-radius:7;
                                  -fx-background-radius:7;
                                  -fx-table-cell-border-color:#f1f5f9;
                                  -fx-font-size:13px;">
                    <columns>
                        <TableColumn fx:id="colHistoryGuest" text="Guest"        prefWidth="220"/>
                        <TableColumn fx:id="colAction"       text="Action"       prefWidth="220"/>
                        <TableColumn fx:id="colDate"         text="Date &amp; Time" prefWidth="300"/>
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </content>
</ScrollPane>