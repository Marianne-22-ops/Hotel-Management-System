<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            fitToHeight="false"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PaymentController"
            style="-fx-background-color:#1e293b;
                   -fx-background:#1e293b;"
            prefWidth="650"
            prefHeight="462"
            minWidth="650"
            minHeight="462">

    <content>
        <VBox spacing="12"
              style="-fx-background-color:#1e293b;
                     -fx-padding:16;">

            <!-- PAGE TITLE -->
            <Label text="Payments"
                   style="-fx-font-size:18px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#f1f5f9;"/>

            <!-- FORM CARD -->
            <VBox spacing="10"
                  style="-fx-background-color:white;
                         -fx-padding:14;
                         -fx-background-radius:10;">

                <Label text="PAYMENT DETAILS"
                       style="-fx-font-size:10px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#94a3b8;"/>

                <!-- INPUT ROW -->
                <HBox spacing="10">

                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Guest"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="guestCombo"
                                  promptText="Select Guest"
                                  prefHeight="32"
                                  maxWidth="1.7976931348623157E308"
                                  style="-fx-background-color:#f8fafc;
                                         -fx-border-color:#e2e8f0;
                                         -fx-border-radius:6;
                                         -fx-background-radius:6;
                                         -fx-font-size:13px;"
                                  HBox.hgrow="ALWAYS"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="140">
                        <Label text="Room"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <TextField fx:id="roomField"
                                   promptText="Room"
                                   editable="false"
                                   prefHeight="32"
                                   prefWidth="140"
                                   style="-fx-background-color:#f1f5f9;
                                          -fx-border-color:#e2e8f0;
                                          -fx-border-radius:6;
                                          -fx-background-radius:6;
                                          -fx-padding:4 10;
                                          -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="155">
                        <Label text="Amount"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <TextField fx:id="amountField"
                                   promptText="Auto Amount"
                                   editable="false"
                                   prefHeight="32"
                                   prefWidth="155"
                                   style="-fx-background-color:#f1f5f9;
                                          -fx-border-color:#e2e8f0;
                                          -fx-border-radius:6;
                                          -fx-background-radius:6;
                                          -fx-padding:4 10;
                                          -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" prefWidth="150">
                        <Label text="Payment Method"
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <ComboBox fx:id="methodCombo"
                                  promptText="Payment Method"
                                  prefHeight="32"
                                  prefWidth="150"
                                  style="-fx-background-color:#f8fafc;
                                         -fx-border-color:#e2e8f0;
                                         -fx-border-radius:6;
                                         -fx-background-radius:6;
                                         -fx-font-size:13px;"/>
                    </VBox>

                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Reference No."
                               style="-fx-font-size:11px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <TextField fx:id="referenceField"
                                   promptText="Reference No (optional)"
                                   prefHeight="32"
                                   maxWidth="1.7976931348623157E308"
                                   style="-fx-background-color:#f8fafc;
                                          -fx-border-color:#e2e8f0;
                                          -fx-border-radius:6;
                                          -fx-background-radius:6;
                                          -fx-padding:4 10;
                                          -fx-font-size:13px;"
                                   HBox.hgrow="ALWAYS"/>
                    </VBox>

                </HBox>

                <Separator/>

                <!-- ACTIONS -->
                <Label text="ACTIONS"
                       style="-fx-font-size:10px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="Record Payment"
                            onAction="#recordPayment"
                            prefHeight="32"
                            style="-fx-background-color:#2563eb; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="searchField"
                               promptText="Search Guest..."
                               prefHeight="32"
                               prefWidth="200"
                               style="-fx-background-color:#f8fafc;
                                      -fx-border-color:#e2e8f0;
                                      -fx-border-radius:6;
                                      -fx-background-radius:6;
                                      -fx-padding:4 10;
                                      -fx-font-size:13px;"/>
                    <Button text="Search"
                            onAction="#searchPayment"
                            prefHeight="32"
                            style="-fx-background-color:#0f172a; -fx-text-fill:white;
                                   -fx-font-size:13px; -fx-font-weight:bold;
                                   -fx-background-radius:6; -fx-padding:4 14; -fx-cursor:hand;"/>
                </HBox>

            </VBox>

            <!-- PAYMENT HISTORY TABLE CARD -->
            <VBox spacing="8"
                  style="-fx-background-color:white;
                         -fx-padding:14;
                         -fx-background-radius:10;">

                <Label text="PAYMENT HISTORY"
                       style="-fx-font-size:10px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#94a3b8;"/>

                <TableView fx:id="paymentTable"
                           prefHeight="300"
                           maxWidth="1.7976931348623157E308"
                           style="-fx-background-color:transparent;
                                  -fx-border-color:#e2e8f0;
                                  -fx-border-radius:7;
                                  -fx-background-radius:7;
                                  -fx-table-cell-border-color:#f1f5f9;
                                  -fx-font-size:13px;">
                    <columns>
                        <TableColumn fx:id="colGuest"     text="Guest"     prefWidth="150"/>
                        <TableColumn fx:id="colRoom"      text="Room"      prefWidth="100"/>
                        <TableColumn fx:id="colAmount"    text="Amount"    prefWidth="120"/>
                        <TableColumn fx:id="colMethod"    text="Method"    prefWidth="120"/>
                        <TableColumn fx:id="colReference" text="Reference" prefWidth="150"/>
                        <TableColumn fx:id="colDate"      text="Date"      prefWidth="180"/>
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </content>
</ScrollPane>