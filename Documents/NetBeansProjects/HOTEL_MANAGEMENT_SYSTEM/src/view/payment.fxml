<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PaymentController"
            style="-fx-background-color:#1e293b;">

    <children>

        <VBox spacing="20"
              AnchorPane.topAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20"
              AnchorPane.bottomAnchor="20">

            <!-- TITLE -->
            <Label text="Payments"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>

            <!-- FORM -->
            <VBox spacing="10"
                  style="-fx-border-color:#cbd5e1;
                         -fx-border-radius:12;
                         -fx-background-radius:12;
                         -fx-padding:15;
                         -fx-background-color:rgba(255,255,255,0.7);">

                <HBox spacing="10">

                    <!-- ✅ GUEST -->
                    <ComboBox fx:id="guestCombo"
                              promptText="Select Guest"
                              HBox.hgrow="ALWAYS"/>

                    <!-- ✅ FIXED: ROOM FIELD (AUTO) -->
                    <TextField fx:id="roomField"
                               promptText="Room"
                               editable="false"/>

                    <!-- ✅ AMOUNT AUTO -->
                    <TextField fx:id="amountField"
                               promptText="Auto Amount"
                               editable="false"/>

                    <!-- ✅ METHOD -->
                    <ComboBox fx:id="methodCombo"
                              promptText="Payment Method"/>

                </HBox>

                <HBox spacing="10">

                    <TextField fx:id="referenceField"
                               promptText="Reference No (optional)"
                               HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="searchField"
                               promptText="Search Guest..."
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Record Payment"
                            onAction="#recordPayment"
                            style="-fx-background-color:#22c55e; -fx-text-fill:white;"/>

                    <Button text="Search"
                            onAction="#searchPayment"/>

                </HBox>

            </VBox>

            <!-- TABLE -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-border-color:#cbd5e1;
                         -fx-border-radius:12;
                         -fx-background-radius:12;
                         -fx-padding:15;
                         -fx-background-color:rgba(255,255,255,0.7);">

                <Label text="Payment History"
                       style="-fx-font-weight:bold;"/>

                <TableView fx:id="paymentTable"
                           VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colGuest" text="Guest" prefWidth="150"/>
                        <TableColumn fx:id="colRoom" text="Room" prefWidth="100"/>
                        <TableColumn fx:id="colAmount" text="Amount" prefWidth="120"/>
                        <TableColumn fx:id="colMethod" text="Method" prefWidth="120"/>
                        <TableColumn fx:id="colReference" text="Reference" prefWidth="150"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="180"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </children>
</AnchorPane>