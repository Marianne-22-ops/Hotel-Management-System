<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #1e293b;">
    <children>

        <!-- MAIN CONTAINER -->
        <VBox spacing="20"
              AnchorPane.topAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20"
              AnchorPane.bottomAnchor="20">

            <!-- TITLE -->
            <Label text="Reports"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>

            <!-- SUMMARY BOX -->
            <VBox spacing="10"
                  style="-fx-border-color:#cbd5e1; -fx-border-radius:12; -fx-padding:15; -fx-background-color:rgba(255,255,255,0.7);">

                <Label text="System Summary"
                       style="-fx-font-weight:bold;"/>

                <Label text="Total Guests: 120"/>
                <Label text="Occupied Rooms: 85"/>
                <Label text="Available Rooms: 35"/>
                <Label text="Total Revenue: 5000"/>

            </VBox>

            <!-- DAILY ACTIVITY BOX -->
            <VBox spacing="10"
                  style="-fx-border-color:#cbd5e1; -fx-border-radius:12; -fx-padding:15; -fx-background-color:rgba(255,255,255,0.7);">

                <Label text="Today's Activity"
                       style="-fx-font-weight:bold;"/>

                <Label text="New Check-ins: 10"/>
                <Label text="Check-outs: 7"/>
                <Label text="New Reservations: 5"/>

            </VBox>

            <!-- TABLE BOX -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-border-color:#cbd5e1; -fx-border-radius:12; -fx-padding:15; -fx-background-color:rgba(255,255,255,0.7);">

                <Label text="Recent Transactions"
                       style="-fx-font-weight:bold;"/>

                <TableView VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Guest"/>
                        <TableColumn text="Room"/>
                        <TableColumn text="Amount"/>
                        <TableColumn text="Date"/>
                    </columns>
                </TableView>

            </VBox>

        </VBox>

    </children>
</AnchorPane>

